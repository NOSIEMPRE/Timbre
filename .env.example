# ── Model Provider ──────────────────────────────────────────
# Choose one: anthropic | openai
# "openai" works for any OpenAI-compatible API endpoint.
MODEL_PROVIDER=anthropic

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
# MODEL=claude-sonnet-4-6

# ── OpenAI ───────────────────────────────────────────────────
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL=gpt-4o

# ── Chinese Models (OpenAI-compatible) ───────────────────────
# DeepSeek
# OPENAI_API_KEY=your_deepseek_key_here
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# MODEL=deepseek-chat

# 通义千问 (Qwen)
# OPENAI_API_KEY=your_dashscope_key_here
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL=qwen-max

# 智谱 GLM
# OPENAI_API_KEY=your_zhipu_key_here
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MODEL=glm-4

# Kimi (Moonshot)
# OPENAI_API_KEY=your_moonshot_key_here
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# MODEL=moonshot-v1-8k

# 零一万物 (01.AI)
# OPENAI_API_KEY=your_lingyiwanwu_key_here
# OPENAI_BASE_URL=https://api.lingyiwanwu.com/v1
# MODEL=yi-large

# ── Open Source / Local Models ───────────────────────────────
# Ollama (local)
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# MODEL=llama3.1:70b

# LM Studio (local)
# OPENAI_API_KEY=lmstudio
# OPENAI_BASE_URL=http://localhost:1234/v1
# MODEL=your-loaded-model

# vLLM (self-hosted)
# OPENAI_API_KEY=your_vllm_key
# OPENAI_BASE_URL=http://your-server:8000/v1
# MODEL=meta-llama/Llama-3.1-70B-Instruct

# ── Search ───────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key_here

# ── Server ───────────────────────────────────────────────────
# PORT=3000

# ── Browser / Paywall Access ─────────────────────────────────
# Export your browser cookies to a Netscape-format cookies.txt file
# (Chrome extension: "Get cookies.txt LOCALLY"), then point here.
# When set, browse_url will use these cookies to access paywalled content
# (The Information, 晚点 LatePost, TechCrunch, 36Kr, etc.)
# BROWSER_COOKIES_FILE=/Users/you/.timbre-cookies.txt

# ── Obsidian Integration (CLI mode) ──────────────────────────
# Set OBSIDIAN_VAULT_PATH to save profiles directly into your vault.
# Profiles will be saved under <vault>/<subfolder>/ as Markdown files
# with YAML frontmatter compatible with the Dataview plugin.
# If unset, profiles are saved to the local profiles/ directory instead.
# OBSIDIAN_VAULT_PATH=/Users/you/Documents/my-obsidian-vault
# OBSIDIAN_SUBFOLDER=Timbre

# ── Observability (Optional) ──────────────────────────────────
# Set both keys to enable Langfuse tracing for every LLM call.
# Leave unset to run with zero observability overhead.
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
